# Anthropic config for the chatbot's Netlify Function (server-side — NOT shipped
# to the browser, so no VITE_ prefix).
#
# Netlify:    set these in Site settings → Environment variables.
# Local dev:  either put them here in a `.env` file and run `netlify dev`,
#             or paste the key into creds.json (also gitignored).
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Password for the hidden /admin page (chat DB + visitor log viewer).
ADMIN_PASSWORD=choose-a-strong-password

# SMTP mailbox for the sales-campaign engine (sent via nodemailer).
# Gmail/Workspace: host smtp.gmail.com, port 465, and an App Password (not your
# login password). Microsoft 365: smtp.office365.com, port 587.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
SMTP_FROM=Eirim Health <your@email.com>
# Public base URL used for open/click/unsubscribe tracking links in emails.
CAMPAIGN_BASE_URL=https://eirimhealth.com
