# Server-side config for the Netlify Functions (no VITE_ prefix — never shipped
# to the browser). On Netlify: add these under Site settings → Environment
# variables. Locally: put real values in creds.json (gitignored), or a .env file.

# --- Chatbot (Anthropic) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Admin / auth ---
ADMIN_PASSWORD=choose-a-strong-password
SESSION_SECRET=any-long-random-string

# --- Campaign email (SMTP) ---
# Gmail/Workspace: use an App Password (not your login password); your provider
# supplies the host + port. Microsoft 365 uses port 587.
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=465
SMTP_USER=you@your-domain.com
SMTP_PASS=your-app-password
SMTP_FROM=Your Name <you@your-domain.com>

# --- Public base URL for email tracking links — set to your live domain ---
CAMPAIGN_BASE_URL=https://your-site.example.com
